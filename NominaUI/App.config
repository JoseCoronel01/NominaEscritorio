<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup useLegacyV2RuntimeActivationPolicy="true"> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/>
    </startup>
  <appSettings>
    <add key="Path" value="C:\\ReportesXSD\"/>
  </appSettings>
<connectionStrings>
  <add name="db" connectionString="Server=localhost\SQLEXPRESS;Database=Nomina;Integrated Security=True;" providerName="System.Data.SqlClient"/>
  <add name="db2" connectionString="Server=localhost\SQLEXPRESS;Database=Inventario;Integrated Security=True;" providerName="System.Data.SqlClient"/>
</connectionStrings>
</configuration>
